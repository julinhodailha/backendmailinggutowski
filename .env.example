# ─── PostgreSQL Render ───────────────────────────────────────────────────────
# Cole a connection string do seu banco no Render:
# Render Dashboard → seu banco → Connect → External Connection String
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GERE_UM_SECRET_FORTE_AQUI"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Domínios que podem chamar a API (separados por vírgula)
ALLOWED_ORIGINS="https://mailing.gutowski.com.br,https://www.mailing.gutowski.com.br"

# ─── Admin inicial (usado pelo seed) ──────────────────────────────────────────
ADMIN_EMAIL="admin@amanda"
ADMIN_PASSWORD="2563Amanda@gutowski"
ADMIN_NAME="Admin Gutowski"

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3001
